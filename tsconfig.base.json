{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "useDefineForClassFields": false,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@team-orchestration/core": ["libs/core/src/index.ts"],
      "@team-orchestration/ui": ["libs/ui/src/index.ts"],
      "@team-orchestration/shared-types": ["libs/shared-types/src/index.ts"],
      "@team-orchestration/ipc": ["libs/ipc/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
