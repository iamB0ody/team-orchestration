{
  "name": "@team-orchestration/dashboard",
  "version": "0.0.1",
  "description": "Angular 21 browser-side of the team-orchestration dashboard. Renders data from @team-orchestration/dashboard-server over fetch in dev; same contract targets Electron IPC in wave 5+.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ng serve --port 4200 --open",
    "build": "ng build",
    "test": "ng test --watch=false"
  },
